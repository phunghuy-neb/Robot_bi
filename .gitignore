# Virtual Environments - Không push lên Git
.venv/
venv/
ENV/
env/

# Environment variables
.env
.env.*
!.env.example

# Python cache
__pycache__/
*.pyc
*.pyo
*.pyd

# Hugging Face & Model cache
.hf_cache/
**/.hf_cache/

# ChromaDB database & test data
chroma_db/
**/chroma_db/
runtime/_test_db/
runtime/_audit_test_db/
runtime/_family_*_test_db/

# Temporary & log files
logs/
.claude-review/
*.log
*.log.*
tmp_*
*.tmp

# Project specific
ssl/
*.pem
cloudflared.exe
ngrok.exe
*.exe

# OS generated files
.DS_Store
Thumbs.db

# Folder .claude - BẮT BUỘC PHẢI PUSH
!.claude/
!.claude/handoff.md
!.claude/skills/
!.claude/skills/robot-bi-dev/
!.claude/skills/robot-bi-dev/SKILL.md
!.claude/hooks/
!.claude/hooks/block-dangerous-git.sh

# Codex desktop local skill mirror; authoritative tracked copies live in .claude/skills/
.agents/

# Runtime directory (DB, chroma, logs, caches)
runtime/
!runtime/.gitkeep
!runtime/wakeword/
!runtime/wakeword/.gitkeep

# NotebookLM export (artifact sinh lại được bằng build_notebooklm.py — không track)
notebooklm_export/

# Legacy (đã chuyển sang runtime/)
event_queue.json
tasks.json
robot_bi.db
data/
!data/wakeword/
!data/wakeword/positive/
!data/wakeword/positive/.gitkeep
!data/wakeword/negative/
!data/wakeword/negative/.gitkeep

# Frontend build artifacts
node_modules/
dist/
frontend/parent_app/node_modules/
frontend/parent_app/dist/

# CodeGraph local index (not tracked)
.codegraph/
.aider*

# SSL self-signed (tự sinh khi chạy — không commit private key)
ssl/*.pem
