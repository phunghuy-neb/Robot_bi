# ============================================================
#  Robot Bi — File cấu hình môi trường (.env.example)
#  Sao chép file này thành .env rồi điền giá trị thật.
#  CẢNH BÁO: Không commit file .env lên Git!
# ============================================================

# Groq API — lấy từ console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# Gemini API — lấy từ aistudio.google.com
GEMINI_API_KEY=your_gemini_api_key_here

# Cerebras API — primary LLM provider, model set in config.json
CEREBRAS_API_KEY=your_cerebras_api_key_here

# Sambanova API — fallback LLM provider
SAMBANOVA_API_KEY=your_sambanova_api_key_here

# Cloudflare Workers AI — last-resort LLM provider
CLOUDFLARE_API_KEY=your_cloudflare_api_key_here
CLOUDFLARE_ACCOUNT_ID=your_cloudflare_account_id_here

# Web Search — tra cứu thông tin hiện tại (tin tức, thời tiết, giá...)
# Tavily: đăng ký tại app.tavily.com (1,000 search/tháng miễn phí)
TAVILY_API_KEY=your_tavily_api_key_here
# Brave Search: đăng ký tại api.search.brave.com (2,000 search/tháng miễn phí)
BRAVE_API_KEY=your_brave_api_key_here

# Hugging Face API — lấy từ huggingface.com
HF_TOKEN=your_hf_token_here

# Parent App PIN (bắt buộc — server sẽ không khởi động nếu thiếu)
AUTH_PIN=your_secure_pin_here

# Admin account (username + password) — tạo tự động khi DB trống
ADMIN_USERNAME=admin
# BAT BUOC DOI truoc khi chay - khong dung gia tri mac dinh
ADMIN_PASSWORD=REPLACE_WITH_YOUR_SECURE_PASSWORD

# JWT — bắt buộc cho /auth/login/v2, /auth/refresh, /auth/logout
# Sinh secret: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=change_this_to_a_random_64_char_hex_string
JWT_ALGORITHM=HS256

# Robot config
ROBOT_NAME=Bi
CHILD_NAME=
MAX_HISTORY=10
# Family identifier — used to scope conversation threads per family (multi-family Phase 4)
FAMILY_ID=default

# Bat dang ky lan dau setup, TAT ngay sau khi tao xong tai khoan
REGISTRATION_ENABLED=false

# --- Whisper STT ---
WHISPER_MODEL=large-v2
# De trong de tu dong chon microphone that; hoac dien index tu sounddevice.
MIC_DEVICE=
# CPU mode: dung "medium" de giam latency (large-v2 chi dung khi co GPU)
WHISPER_CPU_MODEL=medium
# Wake-word score threshold; ear_stt.py default la 0.5
WAKEWORD_THRESHOLD=0.5
WHISPER_LANGUAGE=vi
STT_RECORD_SECONDS=10

# --- Optional hardware ---
# May hien tai khong co camera; chi bat khi da gan camera that.
CAMERA_ENABLED=false
CAMERA_INDEX=0
# CryDetector can mic thu hai, khong dung chung mic STT.
CRY_DETECTION_ENABLED=true
CRY_MIC_DEVICE=

# --- RAG Memory ---
RAG_MAX_MEMORIES=500

# --- Cloudflare Named Tunnel (de trong = dung quick tunnel nhu cu) ---
# Tao tunnel tai https://one.dash.cloudflare.com -> Zero Trust -> Networks -> Tunnels
CLOUDFLARE_TUNNEL_TOKEN=
# URL co dinh cua tunnel (vi du: https://robot-bi.example.com)
CLOUDFLARE_TUNNEL_URL=

# --- Motor Controller ---
# WiFi mode: dien IP ESP32 sau khi ket noi WiFi (xem Serial Monitor)
# MOTOR_WS_URL=ws://192.168.1.xxx:81
# Serial mode (fallback): COM port khi cam USB
# MOTOR_PORT=COM4

# --- Logging ---
# Level log: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
