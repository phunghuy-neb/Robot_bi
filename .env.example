# ============================================================
#  Robot Bi — Cấu hình môi trường (.env.example)
#  1. Copy file này: cp .env.example .env
#  2. Điền giá trị thật vào .env
#  3. KHÔNG commit file .env lên Git!
# ============================================================

# ============================================================
#  [BẮT BUỘC] — Server không khởi động nếu thiếu
# ============================================================

# PIN đăng nhập Parent App
AUTH_PIN=your_secure_pin_here

# Admin account — tạo tự động khi DB trống
ADMIN_USERNAME=admin
ADMIN_PASSWORD=REPLACE_WITH_YOUR_SECURE_PASSWORD

# JWT — bắt buộc cho login, refresh token, logout
# Sinh secret: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=change_this_to_a_random_64_char_hex_string
JWT_ALGORITHM=HS256

# LLM chính (Cerebras) — đăng ký tại inference.cerebras.ai
CEREBRAS_API_KEY=your_cerebras_api_key_here

# ============================================================
#  [BẮT BUỘC] LLM Fallback Chain
#  Thứ tự: Cerebras → Groq → Sambanova → Gemini → Cloudflare
# ============================================================

# Groq — console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# Sambanova — cloud.sambanova.ai
SAMBANOVA_API_KEY=your_sambanova_api_key_here

# Gemini — aistudio.google.com
GEMINI_API_KEY=your_gemini_api_key_here

# Cloudflare Workers AI — dash.cloudflare.com
CLOUDFLARE_API_KEY=your_cloudflare_api_key_here
CLOUDFLARE_ACCOUNT_ID=your_cloudflare_account_id_here

# ============================================================
#  [KHUYẾN NGHỊ] Web Search — robot biết tin tức, thời tiết...
# ============================================================

# Tavily (AI-optimized, đủ dùng) — đăng ký tại app.tavily.com
# Miễn phí: 1,000 search/tháng
TAVILY_API_KEY=your_tavily_api_key_here

# Brave Search — api.search.brave.com — trả phí ($5/1,000 req), bỏ qua nếu không cần
# BRAVE_API_KEY=your_brave_api_key_here

# ============================================================
#  [TÙY CHỌN] Các tích hợp khác
# ============================================================

# Hugging Face — huggingface.co/settings/tokens
HF_TOKEN=your_hf_token_here

# ============================================================
#  [CẤU HÌNH ROBOT]
# ============================================================

ROBOT_NAME=Bi
CHILD_NAME=
MAX_HISTORY=10
FAMILY_ID=default

# Bật đăng ký lần đầu, TẮT ngay sau khi tạo xong tài khoản
REGISTRATION_ENABLED=false

# ============================================================
#  [STT / MICROPHONE]
# ============================================================

WHISPER_MODEL=large-v2
WHISPER_CPU_MODEL=medium
MIC_DEVICE=
WAKEWORD_THRESHOLD=0.5
WHISPER_LANGUAGE=vi
STT_RECORD_SECONDS=10

# ============================================================
#  [PHẦN CỨNG TÙY CHỌN]
# ============================================================

# Camera — chỉ bật khi đã gắn camera thật
CAMERA_ENABLED=false
CAMERA_INDEX=0

# CryDetector — cần mic thứ hai, không dùng chung mic STT
CRY_DETECTION_ENABLED=true
CRY_MIC_DEVICE=

# ============================================================
#  [RAG MEMORY]
# ============================================================

RAG_MAX_MEMORIES=500

# ============================================================
#  [CLOUDFLARE TUNNEL — để trống = dùng quick tunnel]
# ============================================================

# Tạo tunnel: one.dash.cloudflare.com → Zero Trust → Networks → Tunnels
CLOUDFLARE_TUNNEL_TOKEN=
CLOUDFLARE_TUNNEL_URL=

# ============================================================
#  [MOTOR CONTROLLER — bỏ qua nếu chưa có robot phần cứng]
# ============================================================

# WiFi mode: điền IP ESP32 sau khi kết nối WiFi
# MOTOR_WS_URL=ws://192.168.1.xxx:81

# Serial mode (fallback): COM port khi cắm USB
# MOTOR_PORT=COM4

# ============================================================
#  [LOGGING]
# ============================================================

LOG_LEVEL=INFO
