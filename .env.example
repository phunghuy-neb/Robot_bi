# ════════════════════════════════════════════════════════════
#  Robot Bi — Cấu hình môi trường  (.env.example)
# ════════════════════════════════════════════════════════════
#  Cách dùng:
#    1. Copy file này:  cp .env.example .env
#    2. Điền giá trị thật vào .env
#    3. KHÔNG commit .env lên Git  (.env đã nằm trong .gitignore)
#
#  Mức ưu tiên:
#    [BẮT BUỘC]   thiếu là server không chạy
#    [KHUYẾN NGHỊ] nên có để đủ tính năng
#    [TÙY CHỌN]   tính năng thêm, bỏ trống vẫn chạy
#    [CẤU HÌNH]   tham số thường (không phải secret)
# ════════════════════════════════════════════════════════════


# ════════════════════════════════════════════════════════════
#  PHẦN 1 · [BẮT BUỘC]
# ════════════════════════════════════════════════════════════

# ── 1.1 Xác thực & bảo mật ──────────────────────────────────
# PIN đăng nhập Parent App
AUTH_PIN=your_secure_pin_here

# Admin account — tạo tự động khi DB trống
ADMIN_USERNAME=admin
ADMIN_PASSWORD=REPLACE_WITH_YOUR_SECURE_PASSWORD

# JWT — bắt buộc cho login / refresh token / logout
# Sinh secret: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=change_this_to_a_random_64_char_hex_string
JWT_ALGORITHM=HS256

# ── 1.2 LLM — Cerebras + chuỗi fallback ─────────────────────
# Thứ tự: Cerebras → Groq → Sambanova → Gemini → Cloudflare → DeepSeek
CEREBRAS_API_KEY=your_cerebras_api_key_here     # inference.cerebras.ai
GROQ_API_KEY=your_groq_api_key_here             # console.groq.com
SAMBANOVA_API_KEY=your_sambanova_api_key_here   # cloud.sambanova.ai
GEMINI_API_KEY=your_gemini_api_key_here         # aistudio.google.com
CLOUDFLARE_API_KEY=your_cloudflare_api_key_here # dash.cloudflare.com
CLOUDFLARE_ACCOUNT_ID=your_cloudflare_account_id_here
DEEPSEEK_API_KEY=your_deepseek_api_key_here     # platform.deepseek.com (last resort)


# ════════════════════════════════════════════════════════════
#  PHẦN 2 · [KHUYẾN NGHỊ]
# ════════════════════════════════════════════════════════════

# ── 2.1 Web Search — robot biết tin tức / thời tiết ─────────
# Tavily (AI-optimized, đủ dùng) — app.tavily.com — free 1,000 search/tháng
TAVILY_API_KEY=your_tavily_api_key_here
# Brave Search — api.search.brave.com — trả phí ($5/1,000 req), bỏ qua nếu không cần
# BRAVE_API_KEY=your_brave_api_key_here


# ════════════════════════════════════════════════════════════
#  PHẦN 3 · [TÙY CHỌN] — tính năng thêm
# ════════════════════════════════════════════════════════════

# ── 3.1 Video bài học từ YouTube (allowlist kênh giáo dục) ──
# An toàn: chỉ lấy video từ các kênh khai trong
#          resources/youtube_channels.json (không search mở).
# Bỏ trống YOUTUBE_API_KEY → Parent App dùng nội dung DB/mock.
# Key: console.cloud.google.com → Enable "YouTube Data API v3"
#      → Credentials → API key  (free, ~10,000 unit/ngày)
YOUTUBE_API_KEY=your_youtube_api_key_here
YOUTUBE_LESSONS_ENABLED=true        # false = tắt dù có key
YOUTUBE_MAX_PER_CHANNEL=4           # số video lấy mỗi kênh
YOUTUBE_CACHE_TTL_SECONDS=21600     # cache 6 giờ (tiết kiệm quota)

# ── 3.2 Knowledge APIs — tra cứu ngoài an toàn cho trẻ ──────
# 16/17 nguồn KHÔNG cần key (dictionary, country, math, trivia,
# books, gutenberg, poem, wiki, weather, iss, animal/fun facts,
# joke, pokemon, disney). Chỉ NASA APOD cần key.
# NASA — https://api.nasa.gov (điền tên+email là có ngay).
# Bỏ trống vẫn chạy bằng DEMO_KEY (giới hạn lượt/IP).
NASA_API_KEY=DEMO_KEY
KNOWLEDGE_CACHE_TTL_SECONDS=1800    # cache 30 phút

# ── 3.3 Tích hợp khác ───────────────────────────────────────
# Hugging Face — huggingface.co/settings/tokens
HF_TOKEN=your_hf_token_here


# ════════════════════════════════════════════════════════════
#  PHẦN 4 · [CẤU HÌNH] — tham số thường (không phải secret)
# ════════════════════════════════════════════════════════════

# ── 4.1 Robot ───────────────────────────────────────────────
ROBOT_NAME=Bi
CHILD_NAME=
MAX_HISTORY=10
FAMILY_ID=default
# Bật đăng ký lần đầu, TẮT ngay sau khi tạo xong tài khoản
REGISTRATION_ENABLED=false

# ── 4.2 STT / Microphone ────────────────────────────────────
WHISPER_MODEL=large-v2      # GPU
WHISPER_CPU_MODEL=medium    # CPU fallback
MIC_DEVICE=
WAKEWORD_THRESHOLD=0.5
WHISPER_LANGUAGE=vi
STT_RECORD_SECONDS=10

# ── 4.3 RAG memory ──────────────────────────────────────────
RAG_MAX_MEMORIES=500

# ── 4.4 Logging ─────────────────────────────────────────────
LOG_LEVEL=INFO


# ════════════════════════════════════════════════════════════
#  PHẦN 5 · [PHẦN CỨNG] — bỏ qua nếu chưa có thiết bị
# ════════════════════════════════════════════════════════════

# ── 5.1 Camera (chỉ bật khi đã gắn camera thật) ─────────────
CAMERA_ENABLED=false
CAMERA_INDEX=0

# ── 5.2 CryDetector (cần mic thứ hai, không dùng chung mic STT) ──
CRY_DETECTION_ENABLED=true
CRY_MIC_DEVICE=

# ── 5.3 Cloudflare Tunnel (để trống = dùng quick tunnel) ────
# Tạo tunnel: one.dash.cloudflare.com → Zero Trust → Networks → Tunnels
CLOUDFLARE_TUNNEL_TOKEN=
CLOUDFLARE_TUNNEL_URL=

# ── 5.4 Motor controller ────────────────────────────────────
# WiFi mode: điền IP ESP32 sau khi kết nối WiFi
# MOTOR_WS_URL=ws://192.168.1.xxx:81
# Serial mode (fallback): COM port khi cắm USB
# MOTOR_PORT=COM4
